# Для docker-compose переменные ниже дублируйте в .env в корне репозитория — оттуда их читает compose.

# Локальный запуск backend без Docker — свой URL. В Docker DATABASE_URL собирается в compose.
DATABASE_URL=postgresql://habitflow:habitflow@localhost:5432/habitflow

# Пароль БД в Docker: должен совпадать с тем, что встроен в URL выше для localhost / в compose для db.
# В проде — длинная случайная строка; символы @ : / % в пароле экранируйте в URL или задайте URL вручную.
POSTGRES_USER=habitflow
POSTGRES_PASSWORD=habitflow
POSTGRES_DB=habitflow

JWT_SECRET=replace-with-long-random-string
FRONTEND_ORIGIN=http://localhost:5173
OAUTH_REDIRECT_BASE=http://localhost:8000
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=
SMTP_HOST=
# 587 STARTTLS (рекомендуется из Docker); 465 при таймауте SSL код сам пробует 587
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
# Обход блокировки SMTP из Docker: https://resend.com — ключ и From с проверенного домена (или тестовый from в кабинете Resend)
RESEND_API_KEY=
